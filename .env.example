# Telegram Bot Configuration
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# API Keys (опционально для демо-режима)
WHALE_ALERT_API_KEY=demo_key
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
COINGECKO_API_KEY=

# Database Configuration (для будущего масштабирования)
DATABASE_URL=sqlite:///data/users.db
REDIS_HOST=localhost
REDIS_PORT=6379

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# Demo Mode Settings
DEMO_MODE=true
OFFLINE_CACHE_ENABLED=true

# Monitoring Settings
WHALE_MONITOR_ENABLED=true
PRICE_MONITOR_ENABLED=true
POLL_INTERVAL_SECONDS=30

# Rate Limiting
MAX_ALERTS_PER_MINUTE=10
MAX_SUBSCRIPTIONS_PER_USER=50
